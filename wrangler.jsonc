{
  "name": "api",
  "main": "src/worker.js",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "BUILD_ARCHIVES",
        "class_name": "BuildArchiveStore"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["BuildArchiveStore"]
    }
  ],
  "find_additional_modules": true,
  "preserve_file_names": true,
  "base_dir": "src",
  "rules": [
    {
      "type": "Data",
      "globs": ["assets/rs/*.zip", "assets/rs/**/*.png", "assets/rs/**/*.json", "assets/rs/**/*.mcmeta"],
      "fallthrough": false
    }
  ],
  "workers_dev": true,
  "preview_urls": false,
  "compatibility_date": "2026-03-21",
  "routes": [
    {
      "pattern": "api.nekohouse.cn/*",
      "zone_name": "nekohouse.cn"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}
